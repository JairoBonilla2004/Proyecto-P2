# Ejemplo de configuración de variables de entorno
# Copiar a .env.local y completar con valores reales

# Telegram Notifier
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Git Configuration
BASE_BRANCH=main
HEAD_BRANCH=HEAD

# Paths
MODEL_PATH=../modelo/model_artifacts
REPORT_PATH=reports/security_report.json

# GitHub Actions (automático)
# GITHUB_PR_NUMBER
# GITHUB_SHA
# GITHUB_REPOSITORY
